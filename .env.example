# === ENVIRONMENT VARIABLES ===
# Set nilai API key Anda di sini, lalu rename file ini menjadi .env.local

# 1. GOOGLE PAGESPEED INSIGHTS — dapat dari Google Cloud Console
#    API & Services → Library → PageSpeed Insights API → Enable
#    Credentials → Create Credentials → API Key
PSI_API_KEY=your-pagespeed-api-key-here

# 2. BING WEBMASTER TOOLS — dapat dari Bing Webmaster Tools
#    Settings → API Access → Generate Key
BING_API_KEY=your-bing-api-key-here

# 3. GOOGLE SEARCH CONSOLE — BUTUH SERVICE ACCOUNT JSON FILE
#    Bukan env var! Simpan file JSON sebagai:
#    dreamlab-site/scripts/gsc-credentials.json
#    
#    Cara dapat:
#    Google Cloud Console → Enable "Google Search Console API"
#    Credentials → Create Credentials → Service Account
#    Download JSON → rename → scripts/gsc-credentials.json
#    Lalu tambah email SA ke GSC Settings → Users → Add User (Owner)

# 4. SUPABASE — untuk SEO data. CATATAN: TIDAK dipakai untuk round-robin
#    lead distribution lagi (migration 00001_round_robin.sql sudah
#    deprecated, sistem aktif sekarang pakai Redis/Upstash di #4a & #4b).
#    Dapat dari Project Settings → API → Project URL & anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
#    Service role key (rahasia, hanya untuk server-side API routes):
#    Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 4a. UPSTASH REDIS — sumber kebenaran round-robin lead distribution
#     (src/lib/roundRobin.ts). Dapat dari Upstash Console → Redis
#     database → REST API section.
UPSTASH_REDIS_REST_KV_REST_API_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=your-upstash-rest-token

# 4b. KOMMO CRM — dipakai /api/kommo-comparison untuk cross-check lead
#     internal vs lead asli yang masuk ke tiap CS di Kommo.
KOMMO_SUBDOMAIN=your-subdomain
KOMMO_API_TOKEN=your-kommo-long-lived-token

# 4c. INTERNAL STATS KEY — proteksi endpoint internal
#     (/api/round-robin-stats, /api/kommo-comparison) supaya tidak bisa
#     diakses publik tanpa key. Generate dengan: openssl rand -hex 32
#     Cara pakai saat akses manual: tambah query ?key=... atau header
#     x-internal-key: ...
INTERNAL_STATS_KEY=your-random-internal-key-here

# 5. ISR ON-DEMAND REVALIDATION SECRET — digunakan Supabase Webhook
#    untuk memaksa purge cache Next.js saat data produk/harga berubah
#    Generate dengan: openssl rand -hex 32
REVALIDATION_SECRET=your-random-secret-here
