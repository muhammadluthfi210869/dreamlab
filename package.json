{
  "name": "dreamlab-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:open": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify:redirects": "npx tsx scripts/test-redirects.ts",
    "verify:lead-flow": "npx tsx scripts/verify-thankyou-flow.ts",
    "verify:round-robin": "npx tsx scripts/verify-round-robin-config.ts",
    "simulate:leads": "npx tsx scripts/simulate-lead-distribution.ts",
    "verify:seo": "npx tsx scripts/verify-seo-integrity.ts",
    "verify:sitemap": "node scripts/verify-sitemap-indexability.mjs",
    "verify:assets": "npx tsx scripts/verify-asset-paths.ts",
    "verify:all": "npm run build && npm run verify:redirects && npm run verify:lead-flow && npm run verify:round-robin && npm run verify:seo && npm run verify:assets",
    "crawl:baseline": "npx tsx scripts/crawl-baseline.ts",
    "psi:snapshot": "npx tsx scripts/pagespeed-snapshot.ts",
    "gsc:baseline": "npx tsx scripts/gsc-baseline.ts",
    "preflight": "npm run verify:all"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@upstash/redis": "^1.38.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
